{
  "projectName": "SMART Absen SMA UII (Monorepo Entrypoint)",
  "instructions": "Read .opencode/SHARED/project-context.md and .opencode/SHARED/agent-rules.md for project context. For role-specific instructions, see ~/.openkb/ROLES/<role>.md.",
  "references": [
    "../smauii-playbook",
    "../kaede-powerup",
    "../smauii-core"
  ],
  "customSlashCommands": [
    {
      "name": "test",
      "description": "Run PHPUnit tests",
      "command": "php artisan test"
    },
    {
      "name": "lint",
      "description": "Check coding style with Laravel Pint",
      "command": "./vendor/bin/pint --test"
    },
    {
      "name": "fix",
      "description": "Fix coding style",
      "command": "./vendor/bin/pint"
    },
    {
      "name": "migrate",
      "description": "Run database migrations",
      "command": "php artisan migrate"
    },
    {
      "name": "fresh",
      "description": "Migrate fresh + seed",
      "command": "php artisan migrate:fresh --seed"
    }
  ],
  "ignorePatterns": [
    ".env",
    ".env.*",
    "vendor/",
    "node_modules/",
    "storage/",
    ".openkb/PERSONAL/"
  ]
}
